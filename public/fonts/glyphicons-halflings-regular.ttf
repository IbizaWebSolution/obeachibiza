			.not-admin .product_cat-drinks-packages .single_add_to_cart_button {
    display: none !important;
}

.not-admin .product_cat-drinks-packages form.cart {
    display: none;
}

.not-admin .product_cat-drinks-packages .add_to_cart_button {
    display: none !important;
}
h4.comman-heading {
font-size: calc(2.93333vw + 21.33333px) !important;
    margin: 0 0 39px !important;
    color: #ffa42c;
}
@media(max-width: 768px){
	.home .Header__logo img {margin-top: -30px;}
    .HeroCTA--image-fullscreen {
        height: 50svh !important;
    }
	.page-id-143 .HeroCTA__media img {
    object-fit: cover;
    object-position: 0 90%;
}
	
	.HeroCTA--video {
    height: 50svh !important;
}
	.page-id-21662 .HeroCTA__media img {
    object-fit: cover;
    object-position: 0px -19px;
}
.page-id-16	.HeroCTA .Marquee {
		bottom: 46% !important;
	}
}

.page-template-template-landing-page .Slider--footer, .page-template-template-landing-page section.InstagramFeed {
    display: none;
}
.page-template-template-landing-page section.HeroCTA{margin:0 !important}
.landing-room-button { padding-top: 60px;text-align: center;}
.landing-about-section .landing-about-content p, .heading-landing h2, .landing-room-section .slider-item-text h3, .landing-room-section .slider-item-text p, .landing-hotels-row .landing-hotels-column h3 {color: #000 !important;}

.img-slider .owl-nav{position: relative;max-width: 300px;margin: auto;}

.img-slider .owl-nav button.owl-prev span {display: none; }
.img-slider .owl-nav button.owl-prev {position: absolute; left: 50px; transform: rotate(180deg); top: -3px; }

.img-slider .owl-nav button.owl-prev::before {content: '>';  font-size: 38px;color: #FFF;}

.img-slider .owl-nav button.owl-next span {display: none; }
.img-slider .owl-nav button.owl-next {position: absolute; right: 50px;  }
.img-slider .owl-nav button.owl-next::before {content: '>';  font-size: 38px;color: #FFF;}

.img-slider .owl-dots{padding-bottom: 15px;max-width: 300px;margin: auto;}

.landing-room-section .owl-stage{animation:inherit !important}


.landing-slider .slider-item-content figure .owl-dots, .landing-slider .slider-item-content figure .owl-nav  {
