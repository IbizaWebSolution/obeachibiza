    <script>
    document.addEventListener('DOMContentLoaded', function () {
        if (window.nieValidationAdded) return;
        window.nieValidationAdded = true;

        const form = document.querySelector('form.wpforms-form#wpforms-form-760873');
        if (!form) return;

        const nieWrapper = form.querySelector('.nie-number');
        const spanishWrapper = form.querySelector('.spanish-number');

        const nieField = nieWrapper ? nieWrapper.querySelector('input[type="text"]') : null;
        const spanishField = spanishWrapper ? spanishWrapper.querySelector('input[type="text"]') : null;

        let nieError = nieWrapper ? nieWrapper.querySelector('.nie-error-message') : null;
        let spanishError = spanishWrapper ? spanishWrapper.querySelector('.spanish-error-message') : null;

        // Create error elements if not exist
        if (nieWrapper && !nieError) {
            nieError = document.createElement('div');
            nieError.className = 'nie-error-message';
            nieError.style.cssText = 'color:#d63637;margin-top:5px;font-size:12px;';
            nieWrapper.appendChild(nieError);
        }

        if (spanishWrapper && !spanishError) {
            spanishError = document.createElement('div');
            spanishError.className = 'spanish-error-message';
            spanishError.style.cssText = 'color:#d63637;margin-top:5px;font-size:12px;';
            spanishWrapper.appendChild(spanishError);
        }

        const submitButton = form.querySelector('button[type="submit"]');
        if (!submitButton) return;

        submitButton.addEventListener('click', function (e) {
            let isValid = true;

            const nieVal = nieField ? nieField.value.trim().toUpperCase() : '';
            const spanishVal = spanishField ? spanishField.value.trim().toUpperCase() : '';

            const nieRegex = /^[XYZ]\d{7}[A-Z]$/;
            const spanishRegex = /^\d{8}[A-Z]$/;

            // Reset errors
            if (nieField) {
                nieField.classList.remove('wpforms-error');
                nieWrapper.classList.remove('wpforms-has-error');
                nieError.textContent = '';
            }

            if (spanishField) {
                spanishField.classList.remove('wpforms-error');
                spanishWrapper.classList.remove('wpforms-has-error');
                spanishError.textContent = '';
            }

            // Validation logic
            if (!nieVal && !spanishVal) {

                if (nieField) {
                    nieField.classList.add('wpforms-error');
                    nieWrapper.classList.add('wpforms-has-error');
                    nieError.textContent = 'Please enter either NIE or Spanish ID number.';
                }

                if (spanishField) {
                    spanishField.classList.add('wpforms-error');
                    spanishWrapper.classList.add('wpforms-has-error');
                    spanishError.textContent = 'Please enter either Spanish ID or NIE number.';
                }

                isValid = false;

            } else {

                if (nieVal && !nieRegex.test(nieVal)) {
                    if (nieField) {
                        nieField.classList.add('wpforms-error');
                        nieWrapper.classList.add('wpforms-has-error');
                        nieError.textContent = 'Invalid NIE number format (e.g. X1234567A)';
                    }
                    isValid = false;
                }

                if (spanishVal && !spanishRegex.test(spanishVal)) {
                    if (spanishField) {
                        spanishField.classList.add('wpforms-error');
                        spanishWrapper.classList.add('wpforms-has-error');
                        spanishError.textContent = 'Invalid Spanish ID number format (e.g. 12345678Z)';
                    }
                    isValid = false;
                }
            }

            if (!isValid) {
                e.preventDefault();
                e.stopPropagation();

                // Focus first invalid field
                if (nieField && nieVal && !nieRegex.test(nieVal)) {
                    nieField.focus();
                } else if (spanishField && spanishVal && !spanishRegex.test(spanishVal)) {
                    spanishField.focus();
                } else if (nieField) {
                    nieField.focus();
                } else if (spanishField) {
                    spanishField.focus();
                }
            }

        }, true);
    });
    </script>
    </body>

</html>



