# Cabeceras de seguridad — equivalente Apache del archivo _headers.
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; media-src 'self'; font-src 'self'; connect-src 'self'; frame-src https://www.covermanager.com https://sales.premiumguest.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests"
</IfModule>

# Cache largo para estáticos versionados
<IfModule mod_expires.c>
  ExpiresActive On
  <FilesMatch "\.(css|js|woff2?|ttf)$">
    ExpiresDefault "access plus 1 year"
  </FilesMatch>
  <FilesMatch "\.(webp|jpe?g|png|svg|mp4|pdf)$">
    ExpiresDefault "access plus 1 week"
  </FilesMatch>
</IfModule>
