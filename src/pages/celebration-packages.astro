---
import Base from '../layouts/Base.astro';
import HeroCTA from '../components/HeroCTA.astro';
import CelebrationIntro from '../components/pages/CelebrationIntro.astro';
import CardsRow from '../components/CardsRow.astro';
import meta from '../data/pages-meta.json';
import hero00 from '../data/sections/celebration-packages/00-HeroCTA.json';
import cardsRow01 from '../data/sections/celebration-packages/01-CardsRow.json';
import hero02 from '../data/sections/celebration-packages/02-HeroCTA.json';

const m = meta['celebration-packages'];
---

<Base title={m.title} description={m.description} bodyClass={m.bodyClass}>
  {/* titleTag h2: el h1 de la página lo aporta el hero del intro */}
  <HeroCTA {...hero00.props} titleTag="h2" />
  <CelebrationIntro />
  <article class="content-container more-padding no-margin">
    <CardsRow {...cardsRow01.props} />
    <HeroCTA {...hero02.props} titleTag="h2" />
  </article>
</Base>
