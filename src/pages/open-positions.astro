---
import Base from '../layouts/Base.astro';
import HeroCTA from '../components/HeroCTA.astro';
import TextAndLink from '../components/TextAndLink.astro';
import Carousel from '../components/Carousel.astro';
import PositionsListings from '../components/PositionsListings.astro';
import meta from '../data/pages-meta.json';
import hero00 from '../data/sections/open-positions/00-HeroCTA.json';
import textAndLink01 from '../data/sections/open-positions/01-TextAndLink.json';
import carousel02 from '../data/sections/open-positions/02-Carousel.json';
import positions03 from '../data/sections/open-positions/03-PositionsListings.json';

const m = meta['open-positions'];
---

<Base title={m.title} description={m.description} bodyClass={m.bodyClass}>
  <article class="post" id="post-365681">
    <div class="grid">
      <div class="container">
        <HeroCTA {...hero00.props} />
        <TextAndLink {...textAndLink01.props} />
        <Carousel {...carousel02.props} />
        <PositionsListings {...positions03.props} />
      </div>
    </div>
  </article>
</Base>
