---
interface Props {
  /** Modificador BEM, p. ej. "Marquee--default" */
  modifier?: string;
  /** Objeto g-options original */
  options?: Record<string, unknown>;
  /** HTML de cada Marquee__text, p. ej. "<p>Life should be <strong>celebrated</strong></p>" */
  html: string;
  /** Repeticiones del texto por banda (8 en el original) */
  repeat?: number;
}

const {
  modifier = 'Marquee--default',
  options = { someOption: 'value', transition: 'grow' },
  html,
  repeat = 8,
} = Astro.props;

const items = Array.from({ length: repeat });
---

<div class={`Marquee ${modifier} `} g-component="Marquee" g-options={JSON.stringify(options)}>
	<div class="Marquee__content">
		{items.map(() => (
			<div class="Marquee__text"><Fragment set:html={html} /></div>
		))}
	</div>
	<div aria-hidden="true" class="Marquee__content">
		{items.map(() => (
			<div class="Marquee__text"><Fragment set:html={html} /></div>
		))}
	</div>
</div>
